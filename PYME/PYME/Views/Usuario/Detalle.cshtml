@model PYME.Models.Usuario

<h2>Detalle del Usuario</h2>

<div class="card">
    <div class="card-body">
        <p><strong>Nombre:</strong> @Model.Nombre @Model.Primer_Apellido @Model.Segundo_Apellido</p>
        <p><strong>Username:</strong> @Model.UserName</p>
        <p><strong>Rol:</strong> @Model.RolNombre</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p><strong>Teléfono:</strong> @Model.Telefono</p>
        <p><strong>Dirección:</strong> @Model.Direccion_Exacta</p>
        <p><strong>Estado:</strong> @(Model.Estado ? "Activo" : "Inactivo")</p>

        <a asp-action="Index" class="btn btn-secondary">Volver</a>
        <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-warning">Editar</a>
    </div>
</div>