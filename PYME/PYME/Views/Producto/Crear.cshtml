@model PYME.Models.Producto

@{
    ViewData["Title"] = "Crear Producto";
}

<h2 class="mb-3">Crear Producto</h2>

@if (!ViewData.ModelState.IsValid && ViewContext.HttpContext.Request.Method == "POST")
{
    <div class="alert alert-danger">
        <h5>Por favor corrija los siguientes errores:</h5>
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

@using (Html.BeginForm("Crear", "Producto", FormMethod.Post, new { @class = "row g-3" }))
{
    <div class="col-md-4">
        @Html.LabelFor(m => m.SKU, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.SKU, new { @class = "form-control", placeholder = "Ej: PROD-001" })
        @Html.ValidationMessageFor(m => m.SKU, "", new { @class = "text-danger" })
    </div>

    <div class="col-md-8">
        @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Nombre del producto" })
        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
    </div>

    <div class="col-md-12">
        @Html.LabelFor(m => m.Descripcion, new { @class = "form-label" })
        @Html.TextAreaFor(m => m.Descripcion, 3, 0, new { @class = "form-control", placeholder = "Descripción detallada del producto" })
        @Html.ValidationMessageFor(m => m.Descripcion, "", new { @class = "text-danger" })
    </div>

    <div class="col-md-4">
        @Html.LabelFor(m => m.Precio_Costo, new { @class = "form-label" })
        <div class="input-group">
            <span class="input-group-text">₡</span>
            @Html.TextBoxFor(m => m.Precio_Costo, new { @class = "form-control", type = "number", placeholder = "0" })
        </div>
        @Html.ValidationMessageFor(m => m.Precio_Costo, "", new { @class = "text-danger" })
    </div>

    <div class="col-md-4">
        @Html.LabelFor(m => m.Precio_Venta, new { @class = "form-label" })
        <div class="input-group">
            <span class="input-group-text">₡</span>
            @Html.TextBoxFor(m => m.Precio_Venta, new { @class = "form-control", type = "number", placeholder = "0" })
        </div>
        @Html.ValidationMessageFor(m => m.Precio_Venta, "", new { @class = "text-danger" })
    </div>

    <div class="col-md-4">
        @Html.LabelFor(m => m.Stock_Minimo, new { @class = "form-label" })
        @Html.TextBoxFor(m => m.Stock_Minimo, new { @class = "form-control", type = "number", placeholder = "Ej: 5" })
        @Html.ValidationMessageFor(m => m.Stock_Minimo, "", new { @class = "text-danger" })
    </div>

    <div class="col-md-12">
        <div class="form-check">
            @Html.CheckBoxFor(m => m.Estado, new { @class = "form-check-input" })
            @Html.LabelFor(m => m.Estado, "Producto Activo", new { @class = "form-check-label" })
        </div>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save"></i> Guardar
        </button>
        @Html.ActionLink("Cancelar", "Index", "Producto", null, new { @class = "btn btn-secondary" })
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}