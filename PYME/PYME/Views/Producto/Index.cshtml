@model List<PYME.Models.Producto>
@{
    ViewData["Title"] = "Productos";
}

<h2 class="mb-3">📦 Gestión de Productos</h2>


<div class="row mb-3">
    <div class="col-md-6">
        <input type="text" id="buscador" class="form-control" placeholder="🔍 Buscar por nombre o SKU..." />
    </div>
    <div class="col-md-6 text-end">
        <a asp-action="Crear" class="btn btn-success">
            ➕ Registrar nuevo producto
        </a>
    </div>
</div>
@if (Model.Any(p => p.Stock_Actual <= p.Stock_Minimo))
{
    <div class="alert alert-warning">
        ⚠ Hay productos con stock bajo.
        <a href="/producto/alertas-stock">Ver productos</a>
    </div>
}
<table class="table table-striped">
    <thead>
        <tr>
            <th>SKU</th>
            <th>Nombre</th>
            <th>Precio Costo</th>
            <th>Precio Venta</th>
            <th>Stock Actual</th>
            <th>Stock Mínimo</th>
            <th>Estado</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="tablaProductos">
        @foreach (var producto in Model)
        {
            <tr>
                <td>@producto.SKU</td>
                <td>@producto.Nombre</td>
                <td>₡@producto.Precio_Costo.ToString("N2")</td>
                <td>₡@producto.Precio_Venta.ToString("N2")</td>
                <td>
                    @if (producto.Stock_Actual <= producto.Stock_Minimo)
                    {
                        <span class="badge bg-danger">@producto.Stock_Actual</span>
                    }
                    else
                    {
                        <span class="badge bg-success">@producto.Stock_Actual</span>
                    }
                </td>
                <td>@producto.Stock_Minimo</td>
                <td>
                    @if (producto.Estado)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                </td>
                <td>
                    <a asp-action="Detalle"
                       asp-route-id="@producto.Id_Producto"
                       class="btn btn-primary btn-sm">Ver detalle</a>
                    <a asp-action="Editar"
                       asp-route-id="@producto.Id_Producto"
                       class="btn btn-warning btn-sm">Editar</a>
                    <form asp-action="Eliminar"
                          asp-route-id="@producto.Id_Producto"
                          method="post"
                          style="display:inline;"
                          onsubmit="return confirm('¿Está seguro de eliminar este producto?');">
                        <button type="submit" class="btn btn-danger btn-sm">Eliminar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script>
        $('#buscador').on('input', function () {
            const texto = $(this).val();

            $.ajax({
                url: '/producto/buscar',
                data: { texto: texto },
                success: function (productos) {
                    let filas = '';

                    if (productos.length === 0) {
                        filas = '<tr><td colspan="8" class="text-center text-muted">No se encontraron productos</td></tr>';
                    } else {
                        productos.forEach(function (p) {
                            const stockBadge = p.stock_Actual <= p.stock_Minimo
                                ? `<span class="badge bg-danger">${p.stock_Actual ?? 0}</span>`
                                : `<span class="badge bg-success">${p.stock_Actual ?? 0}</span>`;

                            const estadoBadge = p.estado
                                ? `<span class="badge bg-success">Activo</span>`
                                : `<span class="badge bg-danger">Inactivo</span>`;

                            filas += `
                                <tr>
                                    <td>${p.sku}</td>
                                    <td>${p.nombre}</td>
                                    <td>₡${p.precio_Costo.toLocaleString('es-CR', {minimumFractionDigits: 2})}</td>
                                    <td>₡${p.precio_Venta.toLocaleString('es-CR', {minimumFractionDigits: 2})}</td>
                                    <td>${stockBadge}</td>
                                    <td>${p.stock_Minimo}</td>
                                    <td>${estadoBadge}</td>
                                    <td>
                                        <a href="/producto/detalle/${p.id_Producto}" class="btn btn-primary btn-sm">Ver detalle</a>
                                        <a href="/producto/editar/${p.id_Producto}" class="btn btn-warning btn-sm">Editar</a>
                                    </td>
                                </tr>`;
                        });
                    }

                    $('#tablaProductos').html(filas);
                }
            });
        });
    </script>
}