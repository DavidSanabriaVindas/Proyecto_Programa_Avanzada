@model PYME.Models.Producto

@{
    ViewData["Title"] = "Detalle del Producto";
}

<h2 class="mb-3">Detalle del Producto</h2>

<div class="card shadow" style="max-width: 800px;">
    <div class="card-body">
        <h4 class="card-title">📦 @Model.Nombre</h4>
        <p class="text-muted mb-3"><small>SKU: @Model.SKU</small></p>

        <p class="card-text">
            <strong>Descripción:</strong> @Model.Descripcion <br />
            <strong>Precio Costo:</strong> ₡@Model.Precio_Costo.ToString("N2") <br />
            <strong>Precio Venta:</strong> ₡@Model.Precio_Venta.ToString("N2") <br />
            <strong>Stock Mínimo:</strong> @Model.Stock_Minimo <br />
            <strong>Stock Actual:</strong>
            @if (Model.Stock_Actual <= Model.Stock_Minimo)
            {
                <span class="badge bg-danger">@Model.Stock_Actual ⚠️ Bajo stock</span>
            }
            else
            {
                <span class="badge bg-success">@Model.Stock_Actual</span>
            }
            <br />
            <strong>Estado:</strong>
            @if (Model.Estado)
            {
                <span class="badge bg-success">Activo</span>
            }
            else
            {
                <span class="badge bg-danger">Inactivo</span>
            }
            <br />
            <strong>Fecha Creación:</strong> @Model.Fecha_Creacion?.ToString("dd/MM/yyyy HH:mm") <br />
            <strong>Última Actualización:</strong> @Model.Fecha_Actualizacion?.ToString("dd/MM/yyyy HH:mm")
        </p>

        <hr />

        <h5>📋 Movimientos de Inventario (@Model.MovimientosInvetario.Count)</h5>

        @if (Model.MovimientosInvetario.Any())
        {
            <table class="table table-sm table-striped">
                <thead>
                    <tr>
                        <th>Fecha</th>
                        <th>Tipo</th>
                        <th>Cantidad</th>
                        <th>Descripción</th>
                        <th>Usuario</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var mov in Model.MovimientosInvetario.OrderByDescending(m => m.Fecha_Movimiento))
                    {
                        <tr>
                            <td>@mov.Fecha_Movimiento?.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                @if (mov.Tipo_Movimiento == "Entrada")
                                {
                                    <span class="badge bg-success">Entrada</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Salida</span>
                                }
                            </td>
                            <td>@mov.Cantidad</td>
                            <td>@mov.Descripcion</td>
                            <td>@mov.Usuario?.UserName</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <p class="text-muted">No hay movimientos registrados para este producto.</p>
        }

        <a asp-action="Index" class="btn btn-secondary">
            Volver al listado
        </a>
        <a asp-action="Editar" asp-route-id="@Model.Id_Producto" class="btn btn-warning">
            Editar
        </a>
    </div>
</div>