@model PYME.Models.Cliente

@{
    ViewData["Title"] = "Detalle del Cliente";
}

<h2 class="mb-3">Detalle del Cliente</h2>

<div class="card shadow" style="max-width: 700px;">
    <div class="card-body">
        <h4 class="card-title">👤 @Model.Nombre @Model.Primer_Apellido @Model.Segundo_Apellido</h4>

        <hr />

        <p class="card-text">
            <strong>Teléfono:</strong> @(Model.Telefono?.ToString() ?? "No registrado") <br />
            <strong>Correo:</strong> @(Model.Correo ?? "No registrado") <br />
            <strong>Dirección:</strong> @(Model.Direccion_Exacta ?? "No registrada")
        </p>

        <a asp-action="Index" class="btn btn-secondary">
            Volver al listado
        </a>
        <a asp-action="Editar" asp-route-id="@Model.Id_Cliente" class="btn btn-warning">
            Editar
        </a>
    </div>
</div>