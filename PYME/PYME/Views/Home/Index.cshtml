@{
    ViewData["Title"] = "Sistema PYME";
}

<div class="text-center mt-5">
    <h1 class="mb-4">🏢 Sistema de Gestión PYME</h1>
    <p class="mb-4 text-muted">
        Sistema de Gestión PYME
    </p>

    <div class="d-flex justify-content-center gap-4">
        <a asp-controller="Usuario"
           asp-action="Index"
           class="btn btn-primary btn-lg">Usuarios</a>

        <a asp-controller="Producto"
           asp-action="Index"
           class="btn btn-warning btn-lg">Productos</a>

        <a asp-controller="Movimiento"
           asp-action="Index"
           class="btn btn-danger btn-lg">Movimientos</a>

        <a asp-controller="Cliente"
           asp-action="Index"
           class="btn btn-dark btn-lg">Clientes</a>

        <a asp-controller="Venta"
           asp-action="Index"
           class="btn btn-info btn-lg">Ventas</a>
    </div>
</div>