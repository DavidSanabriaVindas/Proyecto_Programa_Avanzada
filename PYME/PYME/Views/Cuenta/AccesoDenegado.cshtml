@{
    ViewData["Title"] = "Acceso Denegado";
}

<div class="container d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card shadow-lg border-0 text-center p-4" style="max-width: 500px; width: 100%;">

        <div class="card-body">
            <div class="mb-3">
                <i class="bi bi-shield-lock-fill text-danger" style="font-size: 4rem;"></i>
            </div>
            <h2 class="text-danger fw-bold">Acceso Denegado</h2>
            <p class="text-muted mt-3">
                No tienes permisos para acceder a esta página.
                Contacta al administrador.
            </p>
            <a asp-controller="Home" asp-action="Index"
               class="btn btn-primary mt-3 px-4">
                <i class="bi bi-house-door-fill"></i> Volver al inicio
            </a>
        </div>

    </div>
</div>
