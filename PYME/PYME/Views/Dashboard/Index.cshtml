@model PYME.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2>📊 Dashboard - Reportes</h2>
    <span class="text-muted small">🔄 Se actualiza automáticamente cada 60 segundos</span>
</div>

<div class="card mb-4">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label mb-1 small fw-bold">Fecha inicio</label>
                <input type="date" name="fechaInicio" class="form-control form-control-sm"
                       value="@Model.FechaInicio.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-3">
                <label class="form-label mb-1 small fw-bold">Fecha fin</label>
                <input type="date" name="fechaFin" class="form-control form-control-sm"
                       value="@Model.FechaFin.ToString("yyyy-MM-dd")" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">Filtrar</button>
            </div>
            <div class="col-md-2">
                <a asp-action="Index" asp-controller="Dashboard" class="btn btn-outline-secondary btn-sm w-100">Limpiar</a>
            </div>
            <div class="col-md-2">
                <a asp-action="Historial" asp-controller="Dashboard" class="btn btn-outline-primary btn-sm w-100">📋 Historial</a>
            </div>
        </form>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-success h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="card-text small mb-1">Ingreso por Ventas</p>
                        <h3 class="mb-0" id="kpi-ingreso">₡@Model.TotalIngresoVentas.ToString("N0")</h3>
                    </div>
                    <span style="font-size:2rem">💰</span>
                </div>
                <p class="mb-0 mt-2 small opacity-75">
                    @Model.FechaInicio.ToString("dd/MM") - @Model.FechaFin.ToString("dd/MM/yyyy")
                </p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-primary h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="card-text small mb-1">Unidades Vendidas</p>
                        <h3 class="mb-0" id="kpi-unidades">@Model.TotalUnidadesVendidas</h3>
                    </div>
                    <span style="font-size:2rem">📦</span>
                </div>
                <p class="mb-0 mt-2 small opacity-75">En el periodo seleccionado</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white @(Model.ProductosStockBajo.Count > 0 ? "bg-danger" : "bg-secondary") h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="card-text small mb-1">Productos Stock Bajo</p>
                        <h3 class="mb-0" id="kpi-stock">@Model.ProductosStockBajo.Count</h3>
                    </div>
                    <span style="font-size:2rem">⚠️</span>
                </div>
                <p class="mb-0 mt-2 small opacity-75">Requieren reabastecimiento</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info h-100">
            <div class="card-body">
                <div class="d-flex justify-content-between">
                    <div>
                        <p class="card-text small mb-1">Producto Top</p>
                        <h5 class="mb-0" id="kpi-top-nombre">@(Model.ProductoMasVendido?.Nombre ?? "Sin datos")</h5>
                    </div>
                    <span style="font-size:2rem">🏆</span>
                </div>
                <p class="mb-0 mt-2 small opacity-75" id="kpi-top-qty">
                    @(Model.ProductoMasVendido?.CantidadVendida ?? 0) unidades vendidas
                </p>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-12">
        <div class="card">
            <div class="card-header fw-bold">📉 Tendencia de Ventas en el Periodo</div>
            <div class="card-body" style="position: relative; height:250px;">
                <canvas id="chartTendencia" height="80"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-8">
        <div class="card h-100">
            <div class="card-header fw-bold">📈 Movimientos Mensuales @DateTime.Now.Year</div>
            <div class="card-body" style="position: relative; height:300px;">
                <canvas id="chartMensual" height="120"></canvas>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card h-100">
            <div class="card-header fw-bold">🏅 Top 5 Productos Más Vendidos</div>
            <div class="card-body" style="position: relative; height:300px;">
                <canvas id="chartTop5"></canvas>
            </div>
        </div>
    </div>
</div>

<div class="row g-3">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-bold text-danger">⚠️ Productos con Stock Bajo</div>
            @if (Model.ProductosStockBajo.Any())
            {
                <div class="table-responsive">
                    <table class="table table-sm table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>SKU</th>
                                <th>Producto</th>
                                <th>Stock Actual</th>
                                <th>Mínimo</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.ProductosStockBajo)
                            {
                                <tr class="table-danger">
                                    <td><code>@p.SKU</code></td>
                                    <td>@p.Nombre</td>
                                    <td><strong>@p.StockActual</strong></td>
                                    <td>@p.StockMinimo</td>
                                    <td>
                                        <a asp-action="Historial" asp-controller="Dashboard"
                                           asp-route-idProducto="@p.Id_Producto"
                                           class="btn btn-sm btn-outline-primary">Ver</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="card-body text-success">✅ Todos los productos tienen stock suficiente.</div>
            }
        </div>
    </div>
    <div class="col-md-6">
        <div class="card">
            <div class="card-header fw-bold">🏅 Top 5 Más Vendidos (detalle)</div>
            <div class="table-responsive">
                <table class="table table-sm table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Producto</th>
                            <th>Unidades</th>
                            <th>Ingreso Est.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int rank = 1;
                        }
                        @foreach (var p in Model.TopProductos)
                        {
                            <tr>
                                <td><strong>@rank</strong></td>
                                <td>@p.Nombre</td>
                                <td>@p.CantidadVendida</td>
                                <td>₡@p.IngresoGenerado.ToString("N0")</td>
                            </tr>
                            rank++;
                        }
                        @if (!Model.TopProductos.Any())
                        {
                            <tr>
                                <td colspan="4" class="text-center text-muted">Sin ventas en el periodo</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const meses      = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ResumenMensual.Select(r => r.Mes)));
        const ventas     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ResumenMensual.Select(r => r.UnidadesVendidas)));
        const entradas   = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ResumenMensual.Select(r => r.UnidadesIngresadas)));
        const topNombres = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopProductos.Select(t => t.Nombre)));
        const topQty     = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopProductos.Select(t => t.CantidadVendida)));
        const diasFechas = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.VentasDiarias.Select(v => v.Fecha)));
        const diasQty    = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.VentasDiarias.Select(v => v.Unidades)));

        // Línea — tendencia diaria
        new Chart(document.getElementById('chartTendencia'), {
            type: 'line',
            data: {
                labels: diasFechas,
                datasets: [{
                    label: 'Unidades vendidas por día',
                    data: diasQty,
                    borderColor: 'rgba(25, 135, 84, 1)',
                    backgroundColor: 'rgba(25, 135, 84, 0.1)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointHoverRadius: 6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top' } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });

        // Barras — resumen mensual
        new Chart(document.getElementById('chartMensual'), {
            type: 'bar',
            data: {
                labels: meses,
                datasets: [
                    {
                        label: 'Unidades Vendidas',
                        data: ventas,
                        backgroundColor: 'rgba(25, 135, 84, 0.75)',
                        borderColor: 'rgba(25, 135, 84, 1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Unidades Ingresadas',
                        data: entradas,
                        backgroundColor: 'rgba(13, 110, 253, 0.6)',
                        borderColor: 'rgba(13, 110, 253, 1)',
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'top' } },
                scales: { y: { beginAtZero: true, ticks: { precision: 0 } } }
            }
        });

        // Dona — top 5
        new Chart(document.getElementById('chartTop5'), {
            type: 'doughnut',
            data: {
                labels: topNombres.length ? topNombres : ['Sin datos'],
                datasets: [{
                    data: topQty.length ? topQty : [1],
                    backgroundColor: ['#198754', '#0d6efd', '#ffc107', '#dc3545', '#0dcaf0']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { position: 'bottom' } }
            }
        });

        // Auto-refresh KPIs cada 60s
        function refrescarKPIs() {
            const params = new URLSearchParams({
                fechaInicio: '@Model.FechaInicio.ToString("yyyy-MM-dd")',
                fechaFin: '@Model.FechaFin.ToString("yyyy-MM-dd")'
            });
            fetch('/dashboard/kpis?' + params)
                .then(r => r.json())
                .then(d => {
                    document.getElementById('kpi-ingreso').innerText    = '₡' + d.totalIngresoVentas;
                    document.getElementById('kpi-unidades').innerText   = d.totalUnidadesVendidas;
                    document.getElementById('kpi-stock').innerText      = d.stockBajoCount;
                    document.getElementById('kpi-top-nombre').innerText = d.productoTopNombre;
                    document.getElementById('kpi-top-qty').innerText    = d.productoTopCantidad + ' unidades vendidas';
                })
                .catch(console.error);
        }
        setInterval(refrescarKPIs, 60000);
    </script>
}
}