@model List<PYME.Models.MovimientoInventario>
<h2>Movimientos</h2>

<div class="mb-3">
    <a asp-action="Entrada" asp-controller="Movimiento" class="btn btn-success me-2">
        <i class="bi bi-box-arrow-in-down"></i> Entrada
    </a>
    <a asp-action="Salida" asp-controller="Movimiento" class="btn btn-danger">
        <i class="bi bi-box-arrow-up"></i> Salida
    </a>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Producto</th>
            <th>Tipo</th>
            <th>Usuario</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var mov in Model)
        {
            <tr>
                <td>@mov.Fecha_Movimiento</td>
                <td>@mov.Producto?.Nombre</td>
                <td>@mov.Tipo_Movimiento</td>
                <td>@mov.Usuario?.UserName</td>
                <td>
                    <a asp-action="Detalle" asp-controller="Movimiento" asp-route-id="@mov.Id_Movimiento" class="btn btn-sm btn-info">Ver</a>
                </td>
            </tr>
        }
    </tbody>
</table>
</table>