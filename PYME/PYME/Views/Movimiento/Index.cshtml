@model List<PYME.Models.MovimientoInventario>

<h2>Movimientos</h2>

<table class="table">
    <thead>
        <tr>
            <th>Fecha</th>
            <th>Producto</th>
            <th>Tipo</th>
            <th>Usuario</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var mov in Model)
        {
            <tr>
                <td>@mov.Fecha_Movimiento</td>
                <td>@mov.Producto?.Nombre</td>
                <td>@mov.Tipo_Movimiento</td>
                <td>@mov.Usuario?.UserName</td>
                <td>
                    <a asp-action="Detalle" asp-route-id="@mov.Id_Movimiento">Ver</a>
                </td>
            </tr>
        }
    </tbody>
</table>