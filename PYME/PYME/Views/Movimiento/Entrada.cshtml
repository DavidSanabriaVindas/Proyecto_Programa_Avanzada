@model PYME.Models.MovimientoInventario

@{
    ViewData["Title"] = "Registrar Entrada";
}

<h2 class="mb-3">➕ Registrar Entrada de Inventario</h2>

@if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0 && ViewContext.HttpContext.Request.Method == "POST")
{
    <div class="alert alert-danger">
        <h5>Por favor corrija los siguientes errores:</h5>
        <ul>
            @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
            {
                <li>@error.ErrorMessage</li>
            }
        </ul>
    </div>
}

<form asp-action="Entrada" method="post" class="row g-3" style="max-width: 700px;">

    <div class="col-md-12">
        <label asp-for="Id_Producto" class="form-label">Producto *</label>
        <select asp-for="Id_Producto" class="form-select">
            <option value="">Seleccione un producto</option>
            @foreach (var p in ViewBag.Productos as List<PYME.Models.Producto>)
            {
                <option value="@p.Id_Producto">@p.Nombre (SKU: @p.SKU — Stock: @p.Stock_Actual)</option>
            }
        </select>
        <span asp-validation-for="Id_Producto" class="text-danger"></span>
    </div>

    <div class="col-md-12">
        <label asp-for="Id_Usuario" class="form-label">Usuario *</label>
        <select asp-for="Id_Usuario" class="form-select">
            <option value="">Seleccione un usuario</option>
            @foreach (var u in ViewBag.Usuarios as List<PYME.Models.Usuario>)
            {
                <option value="@u.Id_Usuario">@u.Nombre @u.Primer_Apellido — @u.Username</option>
            }
        </select>
        <span asp-validation-for="Id_Usuario" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Cantidad" class="form-label">Cantidad *</label>
        <input asp-for="Cantidad" type="number" class="form-control" min="1" />
        <span asp-validation-for="Cantidad" class="text-danger"></span>
    </div>

    <div class="col-md-6">
        <label asp-for="Descripcion" class="form-label">Descripción *</label>
        <select asp-for="Descripcion" class="form-select"
                asp-items="ViewBag.Descripciones">
            <option value="">Seleccione una descripción</option>
        </select>
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Registrar Entrada
        </button>
        <a asp-action="Index" class="btn btn-secondary">
            <i class="bi bi-arrow-left"></i> Cancelar
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}